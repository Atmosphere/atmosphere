---
const capabilities = [
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2a4 4 0 0 0-4 4v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2h-2V6a4 4 0 0 0-4-4z"/>
      <circle cx="12" cy="15" r="2"/>
      <path d="M12 17v2"/>
    </svg>`,
    title: 'AI Streaming & Agents',
    description: 'Stream LLM tokens to browsers in real time. Built-in RAG, tool calling, guardrails, and an MCP server for AI agents. Adapters for Spring AI, LangChain4j, Google ADK, and Embabel.',
    badge: 'New in 4.0',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
      <path d="m9 12 2 2 4-4"/>
    </svg>`,
    title: 'Transport Layer',
    description: 'WebSocket, SSE, long-polling — your code never changes. Atmosphere picks the best transport, handles fallback, reconnection, heartbeats, and message caching automatically.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="16 18 22 12 16 6"/>
      <polyline points="8 6 2 12 8 18"/>
    </svg>`,
    title: 'Client SDKs',
    description: 'atmosphere.js ships hooks for React, Vue, and Svelte with rooms, presence tracking, offline queues, and streaming out of the box. Also available for React Native.',
  },
  {
    icon: `<svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
      <path d="m12 15-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
      <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
      <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
    </svg>`,
    title: 'Spring Boot & Quarkus',
    description: 'Auto-configured starters for both frameworks. Add one dependency to your existing app — Atmosphere handles the real-time layer without rewiring anything.',
  },
];
---

<section class="atmosphere" id="atmosphere">
  <div class="atmosphere-container">
    <div class="section-header">
      <span class="section-label">Atmosphere 4.0</span>
      <h2 class="section-title">Real-time and AI in one framework</h2>
      <p class="section-description">
        The transport layer, client SDKs, rooms, and AI streaming infrastructure
        your application needs — so you can focus on what makes your product different.
      </p>
    </div>

    <div class="capabilities-grid">
      {capabilities.map((cap, index) => (
        <a href="#support" class="capability-card" style={`--delay: ${(index * 0.1).toFixed(1)}s`}>
          <div class="capability-header">
            <div class="capability-icon" set:html={cap.icon} />
            {cap.badge && <span class="capability-badge">{cap.badge}</span>}
          </div>
          <h3 class="capability-title">{cap.title}</h3>
          <p class="capability-description">{cap.description}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .atmosphere {
    padding: var(--space-4xl) var(--space-xl);
    position: relative;
  }

  .atmosphere::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-accent), transparent);
  }

  .atmosphere-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-3xl);
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .section-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .capabilities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .capability-card {
    padding: var(--space-xl);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: all 0.3s var(--ease-out-quad);
    animation: fadeInUp 0.6s var(--ease-out-expo) var(--delay) both;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .capability-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.5);
  }

  .capability-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .capability-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--color-accent-glow);
    border-radius: 10px;
    color: var(--color-accent);
    transition: all 0.3s var(--ease-out-quad);
  }

  .capability-card:hover .capability-icon {
    background: var(--color-accent);
    color: var(--color-bg-primary);
  }

  .capability-badge {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    background: var(--color-accent-glow);
    padding: 0.2em 0.6em;
    border-radius: 4px;
    border: 1px solid rgba(0, 212, 255, 0.25);
  }

  .capability-title {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .capability-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    .atmosphere {
      padding: var(--space-3xl) var(--space-md);
    }

    .capabilities-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
