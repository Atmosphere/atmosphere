---

<section class="atmosphere" id="atmosphere">
  <div class="atmosphere-container">
    <div class="section-header">
      <span class="section-label">Atmosphere 4.0</span>
      <h2 class="section-title">Real-time and AI in one framework</h2>
      <p class="section-description">
        The transport layer, client SDKs, rooms, and AI streaming infrastructure
        your application needs — so you can focus on what makes your product different.
      </p>
    </div>

    <div class="capabilities-grid">
      {capabilities.map((cap, index) => (
        <article class="capability-card" data-cap={index} role="button" tabindex="0" style={`--delay: ${(index * 0.1).toFixed(1)}s`}>
          <div class="capability-header">
            <div class="capability-icon" set:html={cap.icon} />
            {cap.badge && <span class="capability-badge">{cap.badge}</span>}
          </div>
          <h3 class="capability-title">{cap.title}</h3>
          <p class="capability-description">{cap.description}</p>
          <span class="capability-hint">Click to explore</span>
        </article>
      ))}
    </div>
  </div>

  <!-- Shared modal -->
  <div class="modal-overlay" id="capModal" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true">
      <button class="modal-close" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4l10 10M14 4L4 14"/></svg>
      </button>
      <div class="modal-hero">
        <div class="modal-hero-glow"></div>
        <div class="modal-icon" id="capModalIcon"></div>
        <div class="modal-hero-text">
          <span class="modal-label">Atmosphere 4.0</span>
          <h3 class="modal-title" id="capModalTitle"></h3>
        </div>
      </div>
      <div class="modal-divider"></div>
      <div class="modal-body" id="capModalBody"></div>
    </div>
  </div>
</section>

<script define:vars={{ capabilities }}>
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('capModal');
    const modalIcon = document.getElementById('capModalIcon');
    const modalTitle = document.getElementById('capModalTitle');
    const modalBody = document.getElementById('capModalBody');
    const closeBtn = overlay.querySelector('.modal-close');

    function openModal(index) {
      const c = capabilities[index];
      modalIcon.innerHTML = c.icon;
      modalTitle.textContent = c.title;
      modalBody.innerHTML = c.detail;
      overlay.setAttribute('aria-hidden', 'false');
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    }

    function closeModal() {
      overlay.classList.remove('active');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.capability-card[data-cap]').forEach(card => {
      card.addEventListener('click', () => openModal(Number(card.dataset.cap)));
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(Number(card.dataset.cap)); }
      });
    });

    closeBtn.addEventListener('click', closeModal);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  });
</script>

<style>
  .atmosphere {
    padding: var(--space-4xl) var(--space-xl);
    position: relative;
  }

  .atmosphere::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-accent), transparent);
  }

  .atmosphere-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto var(--space-3xl);
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: var(--space-md);
  }

  .section-description {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .capabilities-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-lg);
  }

  .capability-card {
    padding: var(--space-xl);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    transition: all 0.3s var(--ease-out-quad);
    animation: fadeInUp 0.6s var(--ease-out-expo) var(--delay) both;
    cursor: pointer;
  }

  .capability-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.5);
  }

  .capability-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .capability-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-lg);
  }

  .capability-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    background: var(--color-accent-glow);
    border-radius: 10px;
    color: var(--color-accent);
    transition: all 0.3s var(--ease-out-quad);
  }

  .capability-card:hover .capability-icon {
    background: var(--color-accent);
    color: var(--color-bg-primary);
  }

  .capability-badge {
    font-family: var(--font-mono);
    font-size: 0.625rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    background: var(--color-accent-glow);
    padding: 0.2em 0.6em;
    border-radius: 4px;
    border: 1px solid rgba(0, 212, 255, 0.25);
  }

  .capability-title {
    font-family: var(--font-body);
    font-size: 1.125rem;
    font-weight: 600;
    margin-bottom: var(--space-sm);
  }

  .capability-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .capability-hint {
    display: block;
    margin-top: var(--space-md);
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-accent);
    opacity: 0;
    transform: translateX(-4px);
    transition: all 0.3s var(--ease-out-quad);
  }

  .capability-card:hover .capability-hint {
    opacity: 1;
    transform: translateX(0);
  }

  /* ── Modal ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0);
    pointer-events: none;
    transition: background 0.4s ease, backdrop-filter 0.4s ease;
  }

  .modal-overlay.active {
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(12px);
    pointer-events: auto;
  }

  .modal {
    position: relative;
    width: min(680px, 100%);
    max-height: calc(100vh - var(--space-3xl));
    overflow-y: auto;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    box-shadow: 0 0 0 1px rgba(0, 212, 255, 0.08), 0 24px 64px -16px rgba(0, 0, 0, 0.7);
    transform: translateY(32px) scale(0.95);
    opacity: 0;
    transition: transform 0.4s var(--ease-out-expo), opacity 0.35s ease;
  }

  .modal-overlay.active .modal {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .modal::-webkit-scrollbar { width: 6px; }
  .modal::-webkit-scrollbar-track { background: transparent; }
  .modal::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 3px; }

  .modal-close {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    z-index: 2;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .modal-close:hover {
    color: var(--color-text-primary);
    border-color: var(--color-accent-dim);
    background: rgba(0, 212, 255, 0.08);
  }

  .modal-hero {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-2xl) var(--space-2xl) var(--space-xl);
    overflow: hidden;
  }

  .modal-hero-glow {
    position: absolute;
    top: -60px;
    left: -40px;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(0, 212, 255, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .modal-icon {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-dim));
    border-radius: 14px;
    color: var(--color-bg-primary);
    box-shadow: 0 8px 24px -8px rgba(0, 212, 255, 0.3);
  }

  .modal-hero-text {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-right: var(--space-3xl);
  }

  .modal-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    opacity: 0.8;
  }

  .modal-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .modal-divider {
    height: 1px;
    margin: 0 var(--space-2xl);
    background: linear-gradient(90deg, var(--color-accent-dim), var(--color-border) 40%, transparent);
    opacity: 0.5;
  }

  .modal-body {
    padding: var(--space-xl) var(--space-2xl) var(--space-2xl);
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .modal-body :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .modal-body :global(li) {
    position: relative;
    padding-left: 1.75em;
    line-height: 1.7;
  }

  .modal-body :global(li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.5;
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.3);
  }

  .modal-body :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 640px) {
    .atmosphere {
      padding: var(--space-3xl) var(--space-md);
    }

    .capabilities-grid {
      grid-template-columns: 1fr;
    }

    .capability-hint {
      opacity: 1;
      transform: translateX(0);
    }

    .modal-overlay { padding: var(--space-sm); }
    .modal { border-radius: 16px; }
    .modal-hero { flex-direction: column; align-items: flex-start; padding: var(--space-xl) var(--space-lg) var(--space-lg); }
    .modal-hero-text { padding-right: 0; }
    .modal-divider { margin: 0 var(--space-lg); }
    .modal-body { padding: var(--space-lg); }
  }
</style>
