---

<section class="why" id="why">
  <div class="why-container">
    <div class="section-header">
      <span class="section-label">Why Atmosphere</span>
      <h2 class="section-title">Why developers choose Atmosphere</h2>
    </div>

    <div class="reasons-grid">
      {reasons.map((reason, index) => (
        <article class="reason-card" data-reason={index} role="button" tabindex="0" style={`--delay: ${(index * 0.08).toFixed(2)}s`}>
          <div class="reason-icon" set:html={reason.icon} />
          <div class="reason-content">
            <h3 class="reason-title">{reason.title}</h3>
            <p class="reason-description">{reason.description}</p>
          </div>
        </article>
      ))}
    </div>

    <div class="why-cta">
      <a href="#support" class="btn btn-primary">
        Talk to us
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Why modal -->
  <div class="modal-overlay" id="whyModal" aria-hidden="true">
    <div class="modal" role="dialog" aria-modal="true">
      <button class="modal-close" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 4l10 10M14 4L4 14"/></svg>
      </button>
      <div class="modal-hero">
        <div class="modal-hero-glow"></div>
        <div class="modal-icon" id="whyModalIcon"></div>
        <div class="modal-hero-text">
          <span class="modal-label">Why Atmosphere</span>
          <h3 class="modal-title" id="whyModalTitle"></h3>
        </div>
      </div>
      <div class="modal-divider"></div>
      <div class="modal-body" id="whyModalBody"></div>
    </div>
  </div>
</section>

<script define:vars={{ reasons }}>
  document.addEventListener('DOMContentLoaded', () => {
    const overlay = document.getElementById('whyModal');
    const modalIcon = document.getElementById('whyModalIcon');
    const modalTitle = document.getElementById('whyModalTitle');
    const modalBody = document.getElementById('whyModalBody');
    const closeBtn = overlay.querySelector('.modal-close');

    function openModal(index) {
      const r = reasons[index];
      modalIcon.innerHTML = r.icon;
      modalTitle.textContent = r.title;
      modalBody.innerHTML = r.detail;
      overlay.setAttribute('aria-hidden', 'false');
      overlay.classList.add('active');
      document.body.style.overflow = 'hidden';
      closeBtn.focus();
    }

    function closeModal() {
      overlay.classList.remove('active');
      overlay.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('.reason-card[data-reason]').forEach(card => {
      card.addEventListener('click', () => openModal(Number(card.dataset.reason)));
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(Number(card.dataset.reason)); }
      });
    });

    closeBtn.addEventListener('click', closeModal);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  });
</script>

<style>
  .why {
    padding: var(--space-4xl) var(--space-xl);
    position: relative;
  }

  .why::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-accent), transparent);
  }

  .why-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .reasons-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-3xl);
  }

  .reason-card {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    cursor: pointer;
    transition: all 0.3s var(--ease-out-quad);
    animation: fadeInUp 0.6s var(--ease-out-expo) var(--delay) both;
  }

  .reason-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.5);
  }

  .reason-card:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .reason-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    background: var(--color-accent-glow);
    border-radius: 10px;
    color: var(--color-accent);
    transition: all 0.3s var(--ease-out-quad);
  }

  .reason-card:hover .reason-icon {
    background: var(--color-accent);
    color: var(--color-bg-primary);
  }

  .reason-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .reason-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .why-cta {
    text-align: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s var(--ease-out-quad);
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--color-text-primary);
    color: var(--color-bg-primary);
  }

  .btn-primary:hover {
    background: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px var(--color-accent-glow);
  }

  /* ── Modal (same style as Atmosphere section) ── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xl);
    background: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0);
    pointer-events: none;
    transition: background 0.4s ease, backdrop-filter 0.4s ease;
  }

  .modal-overlay.active {
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(12px);
    pointer-events: auto;
  }

  .modal {
    position: relative;
    width: min(680px, 100%);
    max-height: calc(100vh - var(--space-3xl));
    overflow-y: auto;
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    box-shadow: 0 0 0 1px rgba(0, 212, 255, 0.08), 0 24px 64px -16px rgba(0, 0, 0, 0.7);
    transform: translateY(32px) scale(0.95);
    opacity: 0;
    transition: transform 0.4s var(--ease-out-expo), opacity 0.35s ease;
  }

  .modal-overlay.active .modal {
    transform: translateY(0) scale(1);
    opacity: 1;
  }

  .modal::-webkit-scrollbar { width: 6px; }
  .modal::-webkit-scrollbar-track { background: transparent; }
  .modal::-webkit-scrollbar-thumb { background: var(--color-border); border-radius: 3px; }

  .modal-close {
    position: absolute;
    top: var(--space-lg);
    right: var(--space-lg);
    z-index: 2;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-secondary);
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .modal-close:hover {
    color: var(--color-text-primary);
    border-color: var(--color-accent-dim);
    background: rgba(0, 212, 255, 0.08);
  }

  .modal-hero {
    position: relative;
    display: flex;
    align-items: center;
    gap: var(--space-lg);
    padding: var(--space-2xl) var(--space-2xl) var(--space-xl);
    overflow: hidden;
  }

  .modal-hero-glow {
    position: absolute;
    top: -60px;
    left: -40px;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(0, 212, 255, 0.12) 0%, transparent 70%);
    pointer-events: none;
  }

  .modal-icon {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, var(--color-accent), var(--color-accent-dim));
    border-radius: 14px;
    color: var(--color-bg-primary);
    box-shadow: 0 8px 24px -8px rgba(0, 212, 255, 0.3);
  }

  .modal-hero-text {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-right: var(--space-3xl);
  }

  .modal-label {
    font-family: var(--font-mono);
    font-size: 0.6875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    opacity: 0.8;
  }

  .modal-title {
    font-family: var(--font-display);
    font-size: 1.75rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    line-height: 1.2;
  }

  .modal-divider {
    height: 1px;
    margin: 0 var(--space-2xl);
    background: linear-gradient(90deg, var(--color-accent-dim), var(--color-border) 40%, transparent);
    opacity: 0.5;
  }

  .modal-body {
    padding: var(--space-xl) var(--space-2xl) var(--space-2xl);
    font-size: 0.9375rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
  }

  .modal-body :global(p) { margin-bottom: var(--space-lg); }
  .modal-body :global(p:last-child) { margin-bottom: 0; }
  .modal-body :global(strong) { color: var(--color-text-primary); font-weight: 600; }

  .modal-body :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .modal-body :global(li) {
    position: relative;
    padding-left: 1.75em;
    line-height: 1.7;
  }

  .modal-body :global(li::before) {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-accent);
    opacity: 0.5;
    box-shadow: 0 0 8px rgba(0, 212, 255, 0.3);
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .reasons-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .why { padding: var(--space-3xl) var(--space-md); }
    .reason-card { flex-direction: column; gap: var(--space-md); }
    .btn { width: 100%; justify-content: center; }
    .modal-overlay { padding: var(--space-sm); }
    .modal { border-radius: 16px; }
    .modal-hero { flex-direction: column; align-items: flex-start; padding: var(--space-xl) var(--space-lg) var(--space-lg); }
    .modal-hero-text { padding-right: 0; }
    .modal-divider { margin: 0 var(--space-lg); }
    .modal-body { padding: var(--space-lg); }
  }
</style>
