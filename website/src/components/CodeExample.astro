---
const reasons = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 2a4 4 0 0 0-4 4v2H6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2h-2V6a4 4 0 0 0-4-4z"/>
      <circle cx="12" cy="15" r="2"/>
    </svg>`,
    title: 'Ship AI features without building infrastructure',
    description: 'Atmosphere handles token streaming, tool execution, RAG context injection, and guardrails. You plug in your model — we deliver the output to the browser.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
      <path d="m9 12 2 2 4-4"/>
    </svg>`,
    title: 'Never build a transport layer again',
    description: 'WebSocket negotiation, SSE fallback, reconnection with backoff, heartbeats, message caching — solved once, across every transport, on every container.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
      <circle cx="9" cy="7" r="4"/>
      <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
      <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
    </svg>`,
    title: 'Rooms and presence that just work',
    description: 'Named groups, member tracking, join/leave events, message history, and direct messaging. Add collaborative features to your app in hours, not weeks.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="16 18 22 12 16 6"/>
      <polyline points="8 6 2 12 8 18"/>
    </svg>`,
    title: 'Client SDKs for every framework',
    description: 'React, Vue, Svelte, and React Native hooks with streaming, offline queues, and auth token refresh. One API across all platforms.',
  },
];
---

<section class="why" id="why">
  <div class="why-container">
    <div class="section-header">
      <span class="section-label">Why Atmosphere</span>
      <h2 class="section-title">Why developers choose Atmosphere</h2>
    </div>

    <div class="reasons-grid">
      {reasons.map((reason, index) => (
        <a href="#support" class="reason-card" style={`--delay: ${(index * 0.08).toFixed(2)}s`}>
          <div class="reason-icon" set:html={reason.icon} />
          <div class="reason-content">
            <h3 class="reason-title">{reason.title}</h3>
            <p class="reason-description" set:html={reason.description} />
          </div>
        </a>
      ))}
    </div>

    <div class="why-cta">
      <a href="#support" class="btn btn-primary">
        Talk to us
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .why {
    padding: var(--space-4xl) var(--space-xl);
    position: relative;
  }

  .why::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--color-border-accent), transparent);
  }

  .why-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: var(--space-3xl);
  }

  .section-label {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 400;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .reasons-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-3xl);
  }

  .reason-card {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-xl);
    background: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: all 0.3s var(--ease-out-quad);
    animation: fadeInUp 0.6s var(--ease-out-expo) var(--delay) both;
  }

  .reason-card:hover {
    border-color: var(--color-border-accent);
    transform: translateY(-4px);
    box-shadow: 0 20px 40px -20px rgba(0, 0, 0, 0.5);
  }

  .reason-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    background: var(--color-accent-glow);
    border-radius: 10px;
    color: var(--color-accent);
    transition: all 0.3s var(--ease-out-quad);
  }

  .reason-card:hover .reason-icon {
    background: var(--color-accent);
    color: var(--color-bg-primary);
  }

  .reason-title {
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: var(--space-xs);
  }

  .reason-description {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  .reason-description a {
    color: var(--color-accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
    transition: border-color 0.2s var(--ease-out-quad);
  }

  .reason-description a:hover {
    border-bottom-color: var(--color-accent);
  }

  .why-cta {
    text-align: center;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    padding: var(--space-md) var(--space-xl);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    border-radius: 8px;
    transition: all 0.2s var(--ease-out-quad);
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--color-text-primary);
    color: var(--color-bg-primary);
  }

  .btn-primary:hover {
    background: var(--color-accent);
    transform: translateY(-2px);
    box-shadow: 0 8px 30px var(--color-accent-glow);
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .reasons-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .why {
      padding: var(--space-3xl) var(--space-md);
    }

    .reason-card {
      flex-direction: column;
      gap: var(--space-md);
    }

    .btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
