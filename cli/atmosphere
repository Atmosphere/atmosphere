        SpringApplication.run(Application.class, args);
    }
}
JAVAEOF

    cat > "$project_dir/src/main/resources/application.yml" <<YMLEOF
atmosphere:
  ai:
    api-key: \${LLM_API_KEY:\${GEMINI_API_KEY:}}
    model: \${LLM_MODEL:gemini-2.5-flash}
