<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
    <parent>
        <groupId>org.atmosphere</groupId>
        <artifactId>atmosphere-project</artifactId>
        <version>4.0.43-SNAPSHOT</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <modelVersion>4.0.0</modelVersion>
    <artifactId>atmosphere-quarkus-langchain4j-parent</artifactId>
    <packaging>pom</packaging>
    <name>atmosphere-quarkus-langchain4j-parent</name>
    <description>Quarkus extension that bridges Quarkus LangChain4j's CDI-managed ChatModel beans into Atmosphere's LangChain4jAgentRuntime.</description>
    <url>https://github.com/Atmosphere/atmosphere</url>

    <properties>
        <!-- Same Quarkus pin as atmosphere-quarkus-extension; netty.version
             override mirrors that module since Quarkus 3.31 ships Netty 4.1.x. -->
        <quarkus.version>3.31.3</quarkus.version>
        <netty.version>4.1.130.Final</netty.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <dependency>
                <groupId>io.quarkus</groupId>
                <artifactId>quarkus-bom</artifactId>
                <version>${quarkus.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <modules>
        <module>runtime</module>
        <module>deployment</module>
    </modules>
</project>
