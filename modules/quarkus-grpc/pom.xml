<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
    <parent>
        <groupId>org.atmosphere</groupId>
        <artifactId>atmosphere-project</artifactId>
        <version>4.0.55</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <modelVersion>4.0.0</modelVersion>
    <artifactId>atmosphere-quarkus-grpc-parent</artifactId>
    <packaging>pom</packaging>
    <name>atmosphere-quarkus-grpc-parent</name>
    <description>Quarkus extension wiring Atmosphere's gRPC transport onto Quarkus lifecycle</description>
    <url>https://github.com/Atmosphere/atmosphere</url>

    <properties>
        <quarkus.version>3.36.0</quarkus.version>
        <netty.version>4.1.135.Final</netty.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- Pin Netty 4.1.133 BEFORE the Quarkus BOM so the CVE patches in
                 the parent POM also win for this extension's transitive
                 grpc-netty-shaded resolution. -->
            <dependency>
                <groupId>io.netty</groupId>
                <artifactId>netty-bom</artifactId>
                <version>${netty.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>io.quarkus</groupId>
                <artifactId>quarkus-bom</artifactId>
                <version>${quarkus.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <modules>
        <module>runtime</module>
        <module>deployment</module>
    </modules>
</project>
