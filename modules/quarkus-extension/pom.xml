<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
    <parent>
        <groupId>org.atmosphere</groupId>
        <artifactId>atmosphere-project</artifactId>
        <version>4.0.59</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <modelVersion>4.0.0</modelVersion>
    <artifactId>atmosphere-quarkus-extension-parent</artifactId>
    <packaging>pom</packaging>
    <name>atmosphere-quarkus-extension-parent</name>
    <description>Quarkus extension for Atmosphere Framework</description>
    <url>https://github.com/Atmosphere/atmosphere</url>

    <properties>
        <quarkus.version>3.36.0</quarkus.version>
        <netty.version>4.1.135.Final</netty.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- Netty BOM pinned to 4.1.135.Final, the version Quarkus 3.36.0
                 ships (up from 4.1.132.Final in 3.35.x). Imported BEFORE
                 quarkus-bom and retained as an explicit floor so the patched
                 netty stays in place regardless of transitive drift. 4.1.133
                 patches CVE-2026-42577 (handler-proxy header injection),
                 CVE-2026-42578 (chunked-extension request smuggling), and
                 CVE-2026-41417 (Transfer-Encoding smuggling). Maven
                 dependencyManagement is first-declared-wins for imported BOMs. -->
            <dependency>
                <groupId>io.netty</groupId>
                <artifactId>netty-bom</artifactId>
                <version>${netty.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>io.quarkus</groupId>
                <artifactId>quarkus-bom</artifactId>
                <version>${quarkus.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <modules>
        <module>runtime</module>
        <module>deployment</module>
    </modules>
</project>
