<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
    <parent>
        <groupId>org.atmosphere</groupId>
        <artifactId>atmosphere-project</artifactId>
        <version>4.0.63</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <modelVersion>4.0.0</modelVersion>
    <artifactId>atmosphere-spring-boot-starter</artifactId>
    <packaging>jar</packaging>
    <name>atmosphere-spring-boot-starter</name>
    <description>Spring Boot auto-configuration for Atmosphere Framework</description>
    <url>https://github.com/Atmosphere/atmosphere</url>

    <properties>
        <atmosphere.module.name>org.atmosphere.spring.boot</atmosphere.module.name>
        <!-- Node toolchain used to (re)build the Atmosphere Console from source.
             Node 23.1.0+ is required: node 22.11's bundled npm fails to install
             vite 8 / rolldown's platform-native binding (optionalDependencies bug),
             leaving the console build broken. -->
        <frontend.node.version>v23.1.0</frontend.node.version>
        <frontend.plugin.version>1.15.1</frontend.plugin.version>
    </properties>

    <dependencyManagement>
        <dependencies>
            <!-- netty-bom imported BEFORE spring-boot-dependencies so its
                 first-wins resolution rule pulls 4.2.15.Final across every
                 transitive netty artifact, patching the netty-codec-http /
                 codec-compression / transport-native-epoll CVEs that are
                 still on Spring Boot 4.0.6's pinned 4.2.12.Final line. -->
            <dependency>
                <groupId>io.netty</groupId>
                <artifactId>netty-bom</artifactId>
                <version>${netty.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
            <dependency>
                <groupId>org.springframework.boot</groupId>
                <artifactId>spring-boot-dependencies</artifactId>
                <version>${spring-boot.version}</version>
                <type>pom</type>
                <scope>import</scope>
            </dependency>
        </dependencies>
    </dependencyManagement>

    <dependencies>
        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-runtime</artifactId>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-autoconfigure</artifactId>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-configuration-processor</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>jakarta.servlet</groupId>
            <artifactId>jakarta.servlet-api</artifactId>
            <scope>provided</scope>
        </dependency>

        <dependency>
            <groupId>com.fasterxml.jackson.core</groupId>
            <artifactId>jackson-annotations</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-web-server</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-health</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-actuator-autoconfigure</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>io.micrometer</groupId>
            <artifactId>micrometer-core</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>io.opentelemetry</groupId>
            <artifactId>opentelemetry-api</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>jakarta.inject</groupId>
            <artifactId>jakarta.inject-api</artifactId>
        </dependency>

        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-durable-sessions</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-grpc</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-ai</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- Governance decision-log audit sinks. Optional: the JDBC/Postgres
             and Kafka auto-configurations only activate when the matching module
             is present AND a connection target is configured (default OFF). -->
        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-ai-audit-postgres</artifactId>
            <version>${project.version}</version>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-ai-audit-kafka</artifactId>
            <version>${project.version}</version>
            <optional>true</optional>
        </dependency>

        <!-- Bundled crash-durable SQLite effect journal for durable agent runs.
             Optional: when absent and durable runs are enabled, the autoconfig
             falls back to the in-memory journal and logs that it is not
             crash-durable (Correctness Invariant #5). -->
        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-checkpoint</artifactId>
            <version>${project.version}</version>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-interactions</artifactId>
            <version>${project.version}</version>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-agent</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-coordinator</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- Admin control plane: available on every Spring Boot sample at
             /atmosphere/admin/. Pulled in non-optionally so users don't have
             to opt each sample in; consumers that specifically want a lean
             bundle can <exclude> this dependency. -->
        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-admin</artifactId>
        </dependency>

        <!-- Plan-and-verify: optional. When present (with a PlanAndVerify
             bean) the admin endpoint exposes /api/admin/verifier/** and the
             console shows the Validation tab. -->
        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-verifier</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-mcp</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-a2a</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-agui</artifactId>
            <optional>true</optional>
        </dependency>

        <!-- WebTransport over HTTP/3 (optional — activated by atmosphere.web-transport.enabled) -->
        <dependency>
            <groupId>io.projectreactor.netty</groupId>
            <artifactId>reactor-netty-http</artifactId>
            <optional>true</optional>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-web</artifactId>
            <scope>test</scope>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-actuator</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- Used by LongTermMemoryHttpE2eTest to drive a real
             HTTP roundtrip against a persistent LongTermMemory backend
             and assert the framework's onDisconnect fires through the
             real AiEndpointHandler chain. -->
        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-durable-sessions-sqlite</artifactId>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.awaitility</groupId>
            <artifactId>awaitility</artifactId>
            <scope>test</scope>
        </dependency>

        <!-- In-process JDBC store for the governance audit-sink auto-config test:
             drives admit + deny through the decision log and asserts both rows
             persist. H2's test scope in atmosphere-ai-audit-postgres is not
             transitive through the optional dep, so it is declared here too. -->
        <dependency>
            <groupId>com.h2database</groupId>
            <artifactId>h2</artifactId>
            <version>2.4.240</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-wasync</artifactId>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <!--
              Rebuild the Atmosphere Console from source on every Maven build so the
              served bundle is always generated from the canonical atmosphere.js — no
              committed bundle is the source of truth, so a stale bundle can never drift
              onto the wire. atmosphere.js has no `prepare` script and its dist/ is
              gitignored, so the dist is (re)built first, then the Vue console bundles it.
              Output goes to target/classes (see frontend/vite.config.ts), packaged into
              the JAR at META-INF/resources/atmosphere/console/. Never skipped — not
              even by -Pfastinstall: three publish channels build with that profile,
              and the packaged starter jar must always contain the console. The
              verify-console-packaged check below fails the build if it is missing.
            -->
            <plugin>
                <groupId>com.github.eirslett</groupId>
                <artifactId>frontend-maven-plugin</artifactId>
                <version>${frontend.plugin.version}</version>
                <configuration>
                    <nodeVersion>${frontend.node.version}</nodeVersion>
                    <installDirectory>${project.build.directory}</installDirectory>
                </configuration>
                <executions>
                    <execution>
                        <id>install-node-and-npm</id>
                        <goals>
                            <goal>install-node-and-npm</goal>
                        </goals>
                        <phase>generate-resources</phase>
                    </execution>
                    <execution>
                        <id>atmosphere-js-install</id>
                        <goals>
                            <goal>npm</goal>
                        </goals>
                        <phase>generate-resources</phase>
                        <configuration>
                            <arguments>ci</arguments>
                            <workingDirectory>${project.basedir}/../../atmosphere.js</workingDirectory>
                        </configuration>
                    </execution>
                    <execution>
                        <id>atmosphere-js-build</id>
                        <goals>
                            <goal>npm</goal>
                        </goals>
                        <phase>generate-resources</phase>
                        <configuration>
                            <arguments>run build</arguments>
                            <workingDirectory>${project.basedir}/../../atmosphere.js</workingDirectory>
                        </configuration>
                    </execution>
                    <execution>
                        <id>console-install</id>
                        <goals>
                            <goal>npm</goal>
                        </goals>
                        <phase>generate-resources</phase>
                        <configuration>
                            <!--
                              `ci` gives a clean, lock-faithful install that also resolves vite 8 /
                              rolldown's platform-native optional binding (requires node 23.1.0+;
                              see frontend.node.version) and leaves the lock unchanged, so the
                              build stays reproducible.
                            -->
                            <arguments>ci</arguments>
                            <workingDirectory>${project.basedir}/frontend</workingDirectory>
                        </configuration>
                    </execution>
                    <execution>
                        <!--
                          Type-check + unit-test the console source before bundling.
                          `vite build` does NOT type-check, and the vitest suite (plan
                          parsing, markdown XSS pins) previously ran in no CI lane —
                          a regression would have shipped silently in the bundle.
                        -->
                        <id>console-check</id>
                        <goals>
                            <goal>npm</goal>
                        </goals>
                        <phase>generate-resources</phase>
                        <configuration>
                            <arguments>run check</arguments>
                            <workingDirectory>${project.basedir}/frontend</workingDirectory>
                        </configuration>
                    </execution>
                    <execution>
                        <id>console-build</id>
                        <goals>
                            <goal>npm</goal>
                        </goals>
                        <phase>generate-resources</phase>
                        <configuration>
                            <arguments>run build</arguments>
                            <workingDirectory>${project.basedir}/frontend</workingDirectory>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
            <!--
              Packaging gate: the starter jar must always contain the Atmosphere Console.
              No committed bundle exists (the console is rebuilt from source above), so a
              skipped/broken frontend build would otherwise ship a console-less jar
              undetected through the publish channels. Bound to `package` (after the
              default maven-jar-plugin binding) so install/deploy/release all hit it.
            -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-antrun-plugin</artifactId>
                <version>3.1.0</version>
                <executions>
                    <execution>
                        <id>verify-console-packaged</id>
                        <goals>
                            <goal>run</goal>
                        </goals>
                        <phase>package</phase>
                        <configuration>
                            <target>
                                <condition property="console.packaged">
                                    <resourceexists>
                                        <zipentry zipfile="${project.build.directory}/${project.build.finalName}.jar"
                                                  name="META-INF/resources/atmosphere/console/index.html"/>
                                    </resourceexists>
                                </condition>
                                <fail unless="console.packaged"
                                      message="Atmosphere Console missing from ${project.build.finalName}.jar: META-INF/resources/atmosphere/console/index.html was not packaged. The frontend build must run on every build — do not skip it."/>
                            </target>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
