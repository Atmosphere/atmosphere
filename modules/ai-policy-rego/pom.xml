<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
    <parent>
        <groupId>org.atmosphere</groupId>
        <artifactId>atmosphere-project</artifactId>
        <version>4.0.41-SNAPSHOT</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>

    <modelVersion>4.0.0</modelVersion>
    <artifactId>atmosphere-ai-policy-rego</artifactId>
    <packaging>jar</packaging>
    <name>atmosphere-ai-policy-rego</name>
    <description>Rego (Open Policy Agent) PolicyParser for the Atmosphere governance plane</description>
    <url>https://github.com/Atmosphere/atmosphere</url>

    <properties>
        <atmosphere.module.name>org.atmosphere.ai.policy.rego</atmosphere.module.name>
    </properties>

    <dependencies>
        <dependency>
            <groupId>org.atmosphere</groupId>
            <artifactId>atmosphere-ai</artifactId>
            <version>${project.version}</version>
        </dependency>

        <!--
          Rego evaluation shells out to the `opa` binary at runtime — no JVM
          embedded Rego runtime dependency. Operators who want Rego install
          the standard OPA binary (common ops tool). Pure-Java Rego runtimes
          like jregorus can be plugged in via the RegoEvaluator interface.
        -->

        <dependency>
            <groupId>ch.qos.logback</groupId>
            <artifactId>logback-classic</artifactId>
            <version>${logback-version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>
</project>
