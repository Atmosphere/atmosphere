    public String {{methodName}}(@Param("input") String input) {
        logger.info("{}: {{name}} called with: {}", "{{agent.name}}", input);
        // TODO: implement real logic
        return "{{name}} result for: " + input;
    }

{{/agent.tools}}
{{/agent.hasTools}}
}
