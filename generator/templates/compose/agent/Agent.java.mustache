package {{agent.packageName}};

import org.atmosphere.agent.annotation.Agent;
import org.atmosphere.ai.StreamingSession;
import org.atmosphere.ai.annotation.AiTool;
import org.atmosphere.ai.annotation.Param;
import org.atmosphere.ai.annotation.Prompt;
import org.slf4j.Logger;
import org.slf4j.LoggerFactory;

/**
 * {{agent.description}}
 *
 * <p>The skill file at {@code prompts/skill.md} defines this agent's personality,
 * capabilities, and guardrails. The {@code @Prompt} method delegates to the
 * configured AI runtime, which uses the skill file as the system prompt.</p>
 */
@Agent(name = "{{agent.name}}",
       skillFile = "prompts/skill.md",
       description = "{{agent.description}}",
       headless = true)
public class {{agent.className}} {

    private static final Logger logger = LoggerFactory.getLogger({{agent.className}}.class);

    @Prompt
    public void onMessage(String message, StreamingSession session) {
        logger.info("{}: received prompt: {}", "{{agent.name}}", message);
        session.stream(message);
    }
{{#agent.hasTools}}

