atmosphere:
  packages: {{packageName}}

{{#usesLlmConfig}}
llm:
  mode: ${LLM_MODE:remote}
  model: ${LLM_MODEL:gemini-2.5-flash}
  base-url: ${LLM_BASE_URL:}
  api-key: ${LLM_API_KEY:${GEMINI_API_KEY:}}
{{/usesLlmConfig}}
{{#usesSpringAiConfig}}
spring:
  ai:
    openai:
      api-key: ${OPENAI_API_KEY:demo}
      chat:
        options:
          model: ${SPRING_AI_OPENAI_CHAT_OPTIONS_MODEL:gpt-4o-mini}
{{/usesSpringAiConfig}}
{{#usesAdkConfig}}
# ADK uses GOOGLE_API_KEY environment variable directly
{{/usesAdkConfig}}
server:
  port: {{serverPort}}
